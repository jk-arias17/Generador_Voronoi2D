# 2. Funciones auxiliares de geometría

def reparar(geom):
    if geom is None or geom.is_empty:
        return geom
    try:
        from shapely.validation import make_valid
        g2 = make_valid(geom)
        return g2 if (g2 is not None and not g2.is_empty) else geom
    except Exception:
        try:
            g2 = geom.buffer(0)
            return g2 if (g2 is not None and not g2.is_empty) else geom
        except Exception:
            return geom

def separar(geom):
    geom = reparar(geom)
    if geom is None or geom.is_empty:
        return []
    if isinstance(geom, MultiPolygon):
        return [reparar(g) for g in geom.geoms if (g and (not g.is_empty) and g.area > 1e-9)]
    return [geom] if geom.area > 1e-9 else []

def puntos_en_poligono(poligono: Polygon, n: int, max_intentos: int = 400000):
    poligono = reparar(poligono)
    if poligono is None or poligono.is_empty:
        return np.zeros((0, 2))
    minx, miny, maxx, maxy = poligono.bounds
    puntos = []
    intentos = 0
    while len(puntos) < n and intentos < max_intentos:
        intentos += 1
        x = random.uniform(minx, maxx)
        y = random.uniform(miny, maxy)
        if poligono.contains(Point(x, y)):
            puntos.append((x, y))
    return np.array(puntos)

def puntos_en_geom(geom, n: int):
    geom = reparar(geom)
    if geom is None or geom.is_empty or n <= 0:
        return np.zeros((0, 2))
    piezas = separar(geom)
    if not piezas:
        return np.zeros((0, 2))
    areas  = np.array([p.area for p in piezas], dtype=float)
    probs  = areas / areas.sum()
    conteos = np.random.multinomial(n, probs)
    lista_pts = []
    for p, k in zip(piezas, conteos):
        if k <= 0:
            continue
        pts = puntos_en_poligono(p, k)
        if pts.shape[0] > 0:
            lista_pts.append(pts)
    return np.vstack(lista_pts) if lista_pts else np.zeros((0, 2))

def voronoi_recorte(semillas: np.ndarray, region):
    region = reparar(region)
    if region is None or region.is_empty or semillas.shape[0] < 3:
        return []
    minx, miny, maxx, maxy = region.bounds
    L = max(maxx - minx, maxy - miny) * 10.0
    extra = np.array([
        [minx - L, miny - L],
        [minx - L, maxy + L],
        [maxx + L, miny - L],
        [maxx + L, maxy + L],
    ])
    puntos = np.vstack([semillas, extra])
    vor    = Voronoi(puntos)
    celdas = []
    N = semillas.shape[0]
    for i in range(N):
        idx_region = vor.point_region[i]
        reg = vor.regions[idx_region]
        if -1 in reg or len(reg) == 0:
            continue
        celda = reparar(Polygon(vor.vertices[reg]))
        if celda is None or celda.is_empty:
            continue
        clip = reparar(celda.intersection(region))
        if clip is None or clip.is_empty:
            continue
        if isinstance(clip, MultiPolygon):
            clip = max(clip.geoms, key=lambda g: g.area)
            clip = reparar(clip)
        if clip is not None and (not clip.is_empty) and clip.area > 1e-9:
            celdas.append(clip)
    return celdas


# 3. Índice espacial y generadores de puntos

def armar_indice(celdas):
    return STRtree(celdas)

def celda_en_punto(tree, celdas, x, y):
    p    = Point(float(x), float(y))
    cand = tree.query(p)
    if len(cand) == 0:
        return None
    primero = cand[0]
    if hasattr(primero, "contains"):
        # Shapely 1.x
        for g in cand:
            if g.contains(p):
                for i, cc in enumerate(celdas):
                    if cc is g:
                        return i
                for i, cc in enumerate(celdas):
                    if cc.equals(g):
                        return i
        return None
    else:
        # Shapely 2.x
        for idx in cand:
            ii = int(idx)
            if celdas[ii].contains(p):
                return ii
        return None

def puntos_grilla(B, H, nx=10, ny=10):
    while True:
        celdillas = [(i, j) for i in range(nx) for j in range(ny)]
        random.shuffle(celdillas)
        for i, j in celdillas:
            x0 = (i / nx) * B;  x1 = ((i + 1) / nx) * B
            y0 = (j / ny) * H;  y1 = ((j + 1) / ny) * H
            yield (random.uniform(x0, x1), random.uniform(y0, y1))

def encoger(poligono, g):
    poligono = reparar(poligono)
    if poligono is None or poligono.is_empty:
        return None
    p = reparar(poligono.buffer(-g, join_style=2))
    if p is None or p.is_empty:
        return None
    if isinstance(p, MultiPolygon):
        p = max(p.geoms, key=lambda gg: gg.area)
        p = reparar(p)
    return p if (p is not None and not p.is_empty and p.area > 1e-9) else None

def escalar(poligono, area_obj):
    poligono = reparar(poligono)
    if poligono is None or poligono.is_empty or poligono.area <= 1e-12:
        return None
    s = math.sqrt(area_obj / poligono.area)
    if s <= 0:
        return None
    from shapely import affinity
    p2 = reparar(affinity.scale(poligono, xfact=s, yfact=s, origin="centroid"))
    return p2 if (p2 is not None and not p2.is_empty and p2.area > 1e-9) else None

def aplicar_alargamiento(poligono, e):
    """Estira el polígono preservando el área. e=1.0 sin cambio; e>1 más alargado.
    Se aplica una rotación aleatoria para que la orientación no sea siempre horizontal."""
    if e <= 1.0 + 1e-9 or poligono is None or poligono.is_empty:
        return poligono
    from shapely import affinity
    factor = math.sqrt(e)
    angulo = random.uniform(0.0, math.pi)
    p = affinity.scale(poligono, xfact=factor, yfact=1.0 / factor, origin="centroid")
    p = affinity.rotate(p, angulo, origin="centroid", use_radians=True)
    p = reparar(p)
    return p if (p is not None and not p.is_empty and p.area > 1e-9) else poligono

def dimensionar_particula(pin, d_objetivo, e, theta, d_minimo):
    """
    Dimensiona la plantilla `pin` para que el polígono resultante tenga:
        - ancho `d * e` entre vértices extremos a lo largo de la dirección θ  (eje mayor)
        - ancho `d / e` perpendicular a θ                                     (eje menor)
    donde `d` = min(d_objetivo, d_que_cabe_en_la_celda). Esto preserva el
    área equivalente circular π·(d/2)². Si `d` queda por debajo de `d_minimo`
    (no cabe ni siquiera el tamaño mínimo del tipo), retorna (None, 0.0).
    Retorna (polígono_dimensionado, d_aplicado).
    """
    if pin is None or pin.is_empty:
        return None, 0.0
    from shapely import affinity
    elong = max(float(e), 1.0)
    # Rotar para alinear θ con el eje X → medimos Feret diameter como ancho AABB
    p_rot = affinity.rotate(pin, -theta, origin='centroid', use_radians=True)
    minx, miny, maxx, maxy = p_rot.bounds
    w_along = maxx - minx
    w_perp  = maxy - miny
    if w_along <= 1e-9 or w_perp <= 1e-9:
        return None, 0.0
    # d máximo que cabe respetando ambos ejes (con 2% de margen)
    margen = 0.98
    d_cabe_mayor = (w_along * margen) / elong    # L_mayor = d·e  ≤  w_along
    d_cabe_menor = (w_perp  * margen) * elong    # L_menor = d/e  ≤  w_perp
    d_cabe = min(d_cabe_mayor, d_cabe_menor)
    d = min(d_objetivo, d_cabe)
    if d < d_minimo:
        return None, 0.0
    target_mayor = d * elong
    target_menor = d / elong
    sx = target_mayor / w_along
    sy = target_menor / w_perp
    p_rot = affinity.scale(p_rot, xfact=sx, yfact=sy, origin='centroid')
    p = affinity.rotate(p_rot, theta, origin='centroid', use_radians=True)
    p = reparar(p)
    if p is None or p.is_empty or p.area <= 1e-9:
        return None, 0.0
    return p, d

def asegurar_min_lados(poligono, min_l):
    """Garantiza al menos min_l lados dividiendo iterativamente la arista más larga."""
    if min_l <= 2 or poligono is None or poligono.is_empty:
        return poligono
    coords = list(poligono.exterior.coords[:-1])
    while len(coords) < min_l:
        n = len(coords)
        max_d, max_i = -1.0, 0
        for i in range(n):
            x1, y1 = coords[i]
            x2, y2 = coords[(i + 1) % n]
            d = (x2 - x1) ** 2 + (y2 - y1) ** 2
            if d > max_d:
                max_d, max_i = d, i
        x1, y1 = coords[max_i]
        x2, y2 = coords[(max_i + 1) % len(coords)]
        coords.insert(max_i + 1, ((x1 + x2) / 2.0, (y1 + y2) / 2.0))
    p = reparar(Polygon(coords))
    return p if (p is not None and not p.is_empty and p.area > 1e-9) else poligono

def subdividir_matriz(region, area_obj):
    region = reparar(region)
    if region is None or region.is_empty:
        return []
    A = region.area
    n = int(round(A / max(area_obj, 1e-9)))
    n = max(3, min(max_puntos, n))
    if n < 3:
        return separar(region)
    pts = puntos_en_geom(region, n)
    if pts.shape[0] < 3:
        return separar(region)
    celdas = voronoi_recorte(pts, region)
    if len(celdas) > max_celdas:
        celdas = random.sample(celdas, max_celdas)
    union = reparar(unary_union(celdas)) if celdas else None
    if union is not None and (not union.is_empty):
        huecos = reparar(region.difference(union))
        celdas.extend(separar(huecos))
    return celdas

def subdividir_celda(celda, area_obj):
    celda = reparar(celda)
    if celda is None or celda.is_empty:
        return []
    n = int(round(celda.area / max(area_obj, 1e-9)))
    n = max(3, min(250, n))
    pts = puntos_en_poligono(celda, n)
    if pts.shape[0] < 3:
        return [celda]
    return voronoi_recorte(pts, celda)


# 4. Voronoi global

def voronoi_base():
    area_promedio = float((fracciones * areas_media).sum())
    N = int(round(area_total_agg / max(area_promedio, 1e-9)))
    N = max(250, N)
    semillas = np.zeros((N, 2))
    semillas[:, 0] = np.random.rand(N) * B
    semillas[:, 1] = np.random.rand(N) * H
    return voronoi_recorte(semillas, dominio)


# 5. Asignación de agregados (todos los tipos excepto el último)

def asignar_granu(celdas, indices_libres, id_clase, area_obj_clase, tree, gen_puntos,
                  centros, radio_check, radio_factor=1.0, gap_factor=1.0):
    gap = espesor_min[id_clase] * float(gap_factor)
    area_acum = 0.0
    agregados = {}
    usadas    = set()
    libres    = set(indices_libres)

    max_intentos = max(700000, 18000 * max(1, len(indices_libres)))
    rmin   = float(radio_check.get(id_clase, 0.0)) * float(radio_factor)
    r_duro = float(radio_minimo.get(id_clase, 0.0))
    pts = np.array(centros, dtype=float) if len(centros) > 0 else np.zeros((0, 2), dtype=float)
    kdt = cKDTree(pts) if pts.shape[0] > 0 else None
    rebuild_every = 25
    added = 0

    intentos = 0
    while (area_acum < area_obj_clase * (1 - tolerancia)) and (intentos < max_intentos) and libres:
        intentos += 1
        x, y = next(gen_puntos)

        idx = celda_en_punto(tree, celdas, x, y)
        if idx is None or idx not in libres:
            continue

        if kdt is not None and (r_duro > 0.0 or rmin > 0.0):
            cxy = celdas[idx].centroid
            cx, cy = float(cxy.x), float(cxy.y)
            if r_duro > 0.0 and len(kdt.query_ball_point([cx, cy], r=r_duro)) > 0:
                continue
            if rmin > 0.0 and len(kdt.query_ball_point([cx, cy], r=rmin)) > 0:
                continue

        pin = encoger(celdas[idx], gap)
        if pin is None:
            continue

        # Dimensionado por diámetro: cada partícula recibe un d sorteado en [dmin, dmax]
        # y una única dirección θ aleatoria. dimensionar_particula ajusta ancho = d·e
        # a lo largo de θ y ancho = d/e perpendicular (área equivalente ≈ π·(d/2)²).
        dmin_t = tipos_agregados[id_clase - 1]["dmin"]
        dmax_t = tipos_agregados[id_clase - 1]["dmax"]
        theta  = random.uniform(0.0, math.pi)
        d_obj  = random.uniform(dmin_t, dmax_t)
        agg, d_final = dimensionar_particula(pin, d_obj, elongacion, theta, dmin_t)
        if agg is None:
            continue

        # Recortar a pin para preservar el gap con celdas vecinas
        agg = reparar(agg.intersection(pin))
        if agg is None or agg.is_empty:
            continue
        if isinstance(agg, MultiPolygon):
            agg = max(agg.geoms, key=lambda g: g.area)
            agg = reparar(agg)
        if agg is None or agg.is_empty:
            continue

        # Verificación silenciosa: área real vs área circular esperada π·(d/2)²
        area_esperada = math.pi * (d_final / 2.0) ** 2
        desviacion = abs(agg.area - area_esperada) / max(area_esperada, 1e-9)
        if desviacion > 0.10:
            # La forma poligonal se aleja más del 10 % del círculo equivalente;
            # aún así se conserva la partícula para no dejar huecos.
            pass

        agg = asegurar_min_lados(agg, min_lados)
        if agg is None or agg.is_empty:
            continue

        agregados[idx] = agg
        usadas.add(idx)
        libres.remove(idx)
        area_acum += agg.area

        cxy = celdas[idx].centroid
        centros.append((float(cxy.x), float(cxy.y)))
        added += 1
        if added >= rebuild_every:
            pts = np.array(centros, dtype=float)
            kdt = cKDTree(pts) if pts.shape[0] > 0 else None
            added = 0

    return agregados, usadas, area_acum


# 6. Asignación del tipo más fino (último en la lista)

def preparar_celdas_fino(celdas, indices_libres, id_clase):
    area_obj = areas_media[id_clase - 1] / fraccion_agregados
    salida = []
    for i in indices_libres:
        celda = celdas[i]
        if celda.area > 3 * area_obj:
            salida.extend(subdividir_celda(celda, area_obj))
        else:
            salida.append(celda)
    return salida

def asignar_fino(celdas_fino, area_obj, id_clase):
    gap          = espesor_min[id_clase]
    dmin_t       = tipos_agregados[id_clase - 1]["dmin"]
    dmax_t       = tipos_agregados[id_clase - 1]["dmax"]
    area_acum    = 0
    lista_agg    = []
    lista_matriz = []
    celdas_fino  = sorted(celdas_fino, key=lambda p: -p.area)

    for celda in celdas_fino:
        if area_acum >= area_obj * (1 - tolerancia):
            lista_matriz.extend(subdividir_matriz(celda, area_celda_matriz))
            continue
        pin = encoger(celda, gap)
        if pin is None:
            lista_matriz.extend(subdividir_matriz(celda, area_celda_matriz))
            continue

        # Dimensionado por diámetro: sorteo d y θ por partícula
        theta = random.uniform(0.0, math.pi)
        d_obj = random.uniform(dmin_t, dmax_t)
        agg, d_final = dimensionar_particula(pin, d_obj, elongacion, theta, dmin_t)
        if agg is None:
            lista_matriz.extend(subdividir_matriz(celda, area_celda_matriz))
            continue

        agg = reparar(agg.intersection(pin))
        if agg is None or agg.is_empty:
            lista_matriz.extend(subdividir_matriz(celda, area_celda_matriz))
            continue
        if isinstance(agg, MultiPolygon):
            agg = max(agg.geoms, key=lambda g: g.area)
            agg = reparar(agg)
        if agg is None or agg.is_empty:
            lista_matriz.extend(subdividir_matriz(celda, area_celda_matriz))
            continue

        # Verificación silenciosa: área real vs área circular esperada
        area_esperada = math.pi * (d_final / 2.0) ** 2
        desviacion = abs(agg.area - area_esperada) / max(area_esperada, 1e-9)
        if desviacion > 0.10:
            pass  # se conserva la partícula para no dejar huecos

        agg = asegurar_min_lados(agg, min_lados)
        if agg is None or agg.is_empty:
            lista_matriz.extend(subdividir_matriz(celda, area_celda_matriz))
            continue

        lista_agg.append(agg)
        area_acum += agg.area
        anillo = reparar(celda.difference(agg))
        lista_matriz.extend(subdividir_matriz(anillo, area_celda_matriz))

    return lista_agg, lista_matriz, area_acum

def matriz_macro(celdas, aggs_dict, area_obj):
    partes = []
    for idx_celda, agg in aggs_dict.items():
        anillo = reparar(celdas[idx_celda].difference(agg))
        partes.extend(subdividir_matriz(anillo, area_obj))
    return partes


