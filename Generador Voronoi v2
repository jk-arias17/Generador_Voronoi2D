    print(f"Agregados logrados      = {total_agg:10.2f} mm^2 ({100*total_agg/area_dominio:6.2f}%)")
    print(f"Matriz lograda          = {total_mat:10.2f} mm^2 ({100*total_mat/area_dominio:6.2f}%)")
