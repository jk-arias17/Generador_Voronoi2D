def graficar_voronoi_base(celdas):
    """Muestra el diagrama de Voronoi base antes de asignar materiales."""
    cmap = plt.get_cmap("tab20")
    fig, ax = plt.subplots(figsize=(6, 6))
    for i, celda in enumerate(celdas):
        celda = reparar(celda)
        if celda is None or celda.is_empty:
            continue
        xs, ys = celda.exterior.xy
        ax.fill(xs, ys, facecolor=cmap(i % 20), alpha=0.7,
                edgecolor="k", linewidth=0.5, antialiased=False)
    ax.set_aspect("equal", "box")
    ax.set_xlim(0, B); ax.set_ylim(0, H)
    ax.set_xlabel("x [mm]")
    ax.set_ylabel("y [mm]")
    ax.set_title("Diagrama de Voronoi base (antes de modificaciones)")
    plt.tight_layout()
    plt.show()

def graficar(poligonos_matriz, listas_agg):
    """listas_agg: lista de listas de polígonos, una por tipo de agregado."""
    color_mat = (0.85, 0.85, 0.85)
